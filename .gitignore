-- –§—É–Ĺ–ļ—Ü–ł—Ź —Ā–ĺ–∑–ī–į–Ĺ–ł—Ź –≤–ļ–Ľ–į–ī–ļ–ł
local function createTab(name, yPos)
    local tab = Instance.new("TextButton")
    tab.Size = UDim2.new(0.25, 0, 0, 30)
    tab.Position = UDim2.new(0.25 * (yPos-1), 0, 0, 30)
    tab.Text = name
    tab.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    tab.TextColor3 = Color3.fromRGB(255, 255, 255)
    tab.Font = Enum.Font.GothamBold
    tab.TextSize = 14
    tab.Parent = mainFrame
    return tab
end

-- –§—É–Ĺ–ļ—Ü–ł—Ź —Ā–ĺ–∑–ī–į–Ĺ–ł—Ź –ļ–Ĺ–ĺ–Ņ–ļ–ł-–Ņ–Ķ—Ä–Ķ–ļ–Ľ—é—á–į—ā–Ķ–Ľ—Ź
local function createToggle(parent, text, y, setting, default)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.45, 0, 0, 25)
    btn.Position = UDim2.new(0.025, 0, 0, y)
    btn.Text = text .. ": " .. (default and "ON" or "OFF")
    btn.BackgroundColor3 = default and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 12
    btn.Parent = parent
    btn.MouseButton1Click:Connect(function()
        Settings[setting] = not Settings[setting]
        btn.Text = text .. ": " .. (Settings[setting] and "ON" or "OFF")
        btn.BackgroundColor3 = Settings[setting] and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 0, 0)
    end)
end

-- –§—É–Ĺ–ļ—Ü–ł—Ź —Ā–ĺ–∑–ī–į–Ĺ–ł—Ź —Ā–Ľ–į–Ļ–ī–Ķ—Ä–į
local function createSlider(parent, text, y, setting, min, max, default)
    local container = Instance.new("Frame")
    container.Size = UDim2.new(0.45, 0, 0, 25)
    container.Position = UDim2.new(0.025, 0, 0, y)
    container.BackgroundTransparency = 1
    container.Parent = parent

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.6, 0, 1, 0)
    label.Text = text
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.BackgroundTransparency = 1
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.Gotham
    label.TextSize = 12
    label.Parent = container

    local value = Instance.new("TextBox")
    value.Size = UDim2.new(0.4, 0, 1, 0)
    value.Position = UDim2.new(0.6, 0, 0, 0)
    value.Text = tostring(default)
    value.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    value.TextColor3 = Color3.fromRGB(255, 255, 0)
    value.Font = Enum.Font.Gotham
    value.TextSize = 12
    value.Parent = container
    value.FocusLost:Connect(function()
        local val = tonumber(value.Text) or default
        if val < min then val = min end
        if val > max then val = max end
        value.Text = tostring(val)
        Settings[setting] = val
    end)
end

-- –í–ļ–Ľ–į–ī–ļ–ł
local tabMain = createTab("Main", 1)
local tabCombat = createTab("Combat", 2)
local tabTeleport = createTab("Teleport", 3)
local tabMisc = createTab("Misc", 4)

-- –ö–ĺ–Ĺ—ā–Ķ–Ļ–Ĺ–Ķ—Ä—č –ī–Ľ—Ź –ļ–į–∂–ī–ĺ–Ļ –≤–ļ–Ľ–į–ī–ļ–ł
local function createContainer()
    local container = Instance.new("Frame")
    container.Size = UDim2.new(0.95, 0, 0, 230)
    container.Position = UDim2.new(0.025, 0, 0, 65)
    container.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    container.BorderSizePixel = 0
    container.Visible = false
    container.Parent = mainFrame
    return container
end

local mainContainer = createContainer()
local combatContainer = createContainer()
local teleportContainer = createContainer()
local miscContainer = createContainer()

-- –ó–į–Ņ–ĺ–Ľ–Ĺ—Ź–Ķ–ľ Main –≤–ļ–Ľ–į–ī–ļ—É
createToggle(mainContainer, "Godmode", 5, "Godmode", false)
createToggle(mainContainer, "No Damage", 35, "NoDamage", false)
createToggle(mainContainer, "No Hunger", 65, "NoHunger", false)
createToggle(mainContainer, "No Sanity", 95, "NoSanity", false)
createToggle(mainContainer, "Speed Boost", 125, "SpeedBoost", false)
createSlider(mainContainer, "Speed Value", 155, "SpeedValue", 16, 200, 32)
createToggle(mainContainer, "Fly Mode", 185, "FlyMode", false)
createToggle(mainContainer, "Noclip", 215, "Noclip", false)

-- –ó–į–Ņ–ĺ–Ľ–Ĺ—Ź–Ķ–ľ Combat –≤–ļ–Ľ–į–ī–ļ—É
createToggle(combatContainer, "Kill Aura", 5, "KillAura", false)
