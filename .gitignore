-- –ó–į–Ņ–ĺ–Ľ–Ĺ—Ź–Ķ–ľ Teleport –≤–ļ–Ľ–į–ī–ļ—É
local tpLabel = Instance.new("TextLabel")
tpLabel.Size = UDim2.new(1, 0, 0, 20)
tpLabel.Position = UDim2.new(0, 0, 0, 5)
tpLabel.Text = "–Ę–Ķ–Ľ–Ķ–Ņ–ĺ—Ä—ā–į—Ü–ł—Ź (—Ā–ļ–ĺ—Ä–ĺ –Ī—É–ī–Ķ—ā)"
tpLabel.TextColor3 = Color3.fromRGB(255, 255, 0)
tpLabel.BackgroundTransparency = 1
