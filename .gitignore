tpLabel.TextSize = 14
tpLabel.Parent = teleportContainer

-- –ó–į–Ņ–ĺ–Ľ–Ĺ—Ź–Ķ–ľ Misc –≤–ļ–Ľ–į–ī–ļ—É
createToggle(miscContainer, "ESP", 5, "ESP", false)
createToggle(miscContainer, "Bring Items", 35, "BringItems", false)

-- –õ–ĺ–≥–ł–ļ–į –Ņ–Ķ—Ä–Ķ–ļ–Ľ—é—á–Ķ–Ĺ–ł—Ź –≤–ļ–Ľ–į–ī–ĺ–ļ
local function hideAll()
    mainContainer.Visible = false
    combatContainer.Visible = false
    teleportContainer.Visible = false
    miscContainer.Visible = false
end

tabMain.MouseButton1Click:Connect(function() hideAll() mainContainer.Visible = true end)
tabCombat.MouseButton1Click:Connect(function() hideAll() combatContainer.Visible = true end)
tabTeleport.MouseButton1Click:Connect(function() hideAll() teleportContainer.Visible = true end)
tabMisc.MouseButton1Click:Connect(function() hideAll() miscContainer.Visible = true end)

mainContainer.Visible = true -- –Ņ–ĺ–ļ–į–∑—č–≤–į–Ķ–ľ Main –Ņ–ĺ —É–ľ–ĺ–Ľ—á–į–Ĺ–ł—é

-- ========== –õ–ě–ď–ė–ö–ź –°–ö–†–ė–ü–Ę–ź ==========

-- Godmode / No Damage
local function godmodeLoop()
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    
    if Settings.Godmode or Settings.NoDamage then
        hum.MaxHealth = math.huge
        hum.Health = math.huge
    end
end

-- No Hunger / No Sanity (–Ņ–ĺ–ł—Ā–ļ –∑–Ĺ–į—á–Ķ–Ĺ–ł–Ļ)
local function survivalLoop()
    local char = LocalPlayer.Character
    if not char then return end
    
    -- –ü–ĺ–ł—Ā–ļ –∑–Ĺ–į—á–Ķ–Ĺ–ł–Ļ –≥–ĺ–Ľ–ĺ–ī–į –ł —Ä–į—Ā—Ā—É–ī–ļ–į (–∑–į–≤–ł—Ā–ł—ā –ĺ—ā –ł–≥—Ä—č)
    for _, v in pairs(char:GetDescendants()) do
        if v.Name == "Hunger" or v.Name == "Food" then
            if Settings.NoHunger then v.Value = 100 end
        end
        if v.Name == "Sanity" or v.Name == "Mental" then
            if Settings.NoSanity then v.Value = 100 end
        end
    end
end

-- Speed Boost
local function speedLoop()
    local char = LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    
    if Settings.SpeedBoost then
        hum.WalkSpeed = Settings.SpeedValue
    else
        hum.WalkSpeed = 16
    end
end

-- Fly Mode
local function flyLoop()
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    if Settings.FlyMode then
        root.Velocity = Vector3.new(0, 0, 0)
        root.Anchored = true
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
            root.CFrame = root.CFrame + Vector3.new(0, 0.5, 0)
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
            root.CFrame = root.CFrame + Vector3.new(0, -0.5, 0)
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then
            root.CFrame = root.CFrame + root.CFrame.LookVector * 0.5
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then
            root.CFrame = root.CFrame - root.CFrame.LookVector * 0.5
        end
    else
        root.Anchored = false
    end
end

-- Noclip
local function noclipLoop()
    local char = LocalPlayer.Character
    if not char then return end
    
    if Settings.Noclip then
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end
end

-- Kill Aura
local function killAuraLoop()
    if not Settings.KillAura then return end
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj:FindFirstChild("HumanoidRootPart") then
            local hum = obj.Humanoid
            local targetRoot = obj.HumanoidRootPart
            if hum and hum.Health > 0 and targetRoot then
                local dist = (targetRoot.Position - root.Position).Magnitude
                if dist <= Settings.AuraRadius then
                    hum.Health = 0
                end
            end
        end
    end
end

-- ESP
local function espLoop()
    if not Settings.ESP then return end
    
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj:FindFirstChild("HumanoidRootPart") then
            local hum = obj.Humanoid
            if hum and hum.Health > 0 then
                local head = obj:FindFirstChild("Head") or obj:FindFirstChild("HumanoidRootPart")
                if head then
                    -- –°–ĺ–∑–ī–į—Ď–ľ BillboardGui –Ķ—Ā–Ľ–ł –Ĺ–Ķ—ā
                    local existing = head:FindFirstChild("ESP_BOX")
                    if not existing then
                        local billboard = Instance.new("BillboardGui")
                        billboard.Name = "ESP_BOX"
                        billboard.Adornee = head
                        billboard.Size = UDim2.new(0, 100, 0, 30)
                        billboard.StudsOffset = Vector3.new(0, 2, 0)
                        billboard.AlwaysOnTop = true
                        billboard.Parent = head
                        
                        local text = Instance.new("TextLabel")
                        text.Size = UDim2.new(1, 0, 1, 0)
                        text.BackgroundTransparency = 1
                        text.Text = obj.Name
                        text.TextColor3 = Color3.fromRGB(255, 0, 0)
                        text.TextStrokeTransparency = 0.5
                        text.Font = Enum.Font.GothamBold
                        text.TextSize = 12
                        text.Parent = billboard
                    end
                end
            end
        end
    end
    
    -- –£–ī–į–Ľ—Ź–Ķ–ľ ESP —É –ľ–Ķ—Ä—ā–≤—č—Ö
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("BillboardGui") and obj.Name == "ESP_BOX" then
            local parent = obj.Parent
            if parent and parent.Parent and parent.Parent:FindFirstChild("Humanoid") then
                local hum = parent.Parent.Humanoid
                if not hum or hum.Health <= 0 then
                    obj:Destroy()
                end
            else
                obj:Destroy()
            end
        end
    end
end

-- Bring Items
local function bringLoop()
    if not Settings.BringItems then return end
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    for _, v in pairs(Workspace:GetDescendants()) do
        if v:IsA("Part") and v.Name:find("Item") then
            v.CFrame = root.CFrame * CFrame.new(0, 0, -3)
        end
    end
end

-- ========== –ě–°–Ě–ě–í–Ě–ě–ô –¶–ė–ö–õ ==========
RunService.RenderStepped:Connect(function()
    godmodeLoop()
    survivalLoop()
    speedLoop()
    flyLoop()
    noclipLoop()
    killAuraLoop()
    espLoop()
    bringLoop()
end)

-- –ě—á–ł—Ā—ā–ļ–į
LocalPlayer.OnTeleport:Connect(function()
    screenGui:Destroy()
end)

