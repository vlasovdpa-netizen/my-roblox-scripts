    Godmode = false,
    NoDamage = false,
    NoHunger = false,
    NoSanity = false,
    KillAura = false,
    AuraRadius = 20,
    ESP = false,
    BringItems = false,
    SpeedBoost = false,
    SpeedValue = 32,
    FlyMode = false,
    Noclip = false,
}

-- ========== GUI ==========
local playerGui = LocalPlayer:WaitForChild("PlayerGui")
for _, v in pairs(playerGui:GetChildren()) do if v.Name == "RINGTA_STYLE" then v:Destroy() end end

